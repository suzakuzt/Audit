APP_NAME=Audit System
APP_ENV=development
APP_DEBUG=true
APP_DATABASE_URL=sqlite:///./audit_system.db

# DeepSeek API Key，可留空并在前端页面里临时输入
AUDIT_LLM_API_KEY=

# 提取模型
AUDIT_LLM_MODEL=deepseek-chat

# DeepSeek OpenAI 兼容接口地址
AUDIT_LLM_BASE_URL=https://api.deepseek.com

# 请求超时时间（秒）
AUDIT_LLM_TIMEOUT=180

# OCR 深度处理模型；留空时跟随提取模型
AUDIT_OCR_MODEL=

# OCR 最多处理页数，避免扫描件过多时请求过大
AUDIT_OCR_MAX_PAGES=3

# ????? PaddleOCR-VL ????????????? HTTP OCR
AUDIT_PADDLE_OCR_API_URL=
AUDIT_PADDLE_OCR_API_TOKEN=
AUDIT_PADDLE_OCR_API_TIMEOUT=180

# Poppler 工具路径，可按本机安装位置覆盖
AUDIT_PDFINFO_PATH=C:\Program Files\poppler\poppler-24.08.0\Library\bin\pdfinfo.exe
AUDIT_PDFTOTEXT_PATH=C:\Program Files\poppler\poppler-24.08.0\Library\bin\pdftotext.exe
AUDIT_PDFTOPPM_PATH=C:\Program Files\poppler\poppler-24.08.0\Library\bin\pdftoppm.exe

# 运行时临时目录
AUDIT_RUNTIME_TEMP_DIR=.runtime_tmp
AUDIT_VALIDATION_INCLUDE_VISUAL_ASSETS=true
AUDIT_VALIDATION_MAX_PARALLEL=3
